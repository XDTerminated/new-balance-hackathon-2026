{
  "manifest_version": 3,
  "name": "New Balance: Try On Your Vibe",
  "version": "1.0.0",
  "description": "AI-powered vibe-based outfit builder for New Balance",
  "permissions": ["sidePanel", "storage", "activeTab"],
  "host_permissions": ["*://www.newbalance.com/*", "http://localhost:8000/*"],
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.newbalance.com/*"],
      "js": ["content/content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
